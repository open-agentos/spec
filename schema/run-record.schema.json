{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/open-agentos/spec/schema/run-record.schema.json",
  "title": "AgentOS Run Record v6",
  "description": "JSONL schema for agent run records and settlement events. One record per line. Each line MUST be valid JSON.",
  "type": "object",
  "required": ["schema_version", "event", "run_key"],

  "oneOf": [
    { "$ref": "#/definitions/run_record" },
    { "$ref": "#/definitions/settlement_record" }
  ],

  "definitions": {

    "run_record": {
      "description": "One record per agent invocation.",
      "type": "object",
      "required": [
        "schema_version", "event", "run_key",
        "identity", "lifecycle", "execution",
        "cost", "friction", "context",
        "clean_exit", "linkage"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 6 },
        "event": { "type": "string", "const": "run" },
        "run_key": {
          "type": "string",
          "description": "Unique key: '{repo}|{role}|{kind}|{number}|{run_id}|{attempt}'",
          "pattern": "^[^|]+\\|[^|]+\\|[^|]+\\|[^|]+\\|[^|]+\\|[^|]+$"
        },

        "identity": {
          "type": "object",
          "required": ["repo", "role", "kind", "number", "run_id", "attempt", "model_name"],
          "properties": {
            "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
            "role": { "type": "string" },
            "kind": { "type": "string", "enum": ["issue", "pr"] },
            "number": { "type": "integer", "minimum": 1 },
            "agent_identity": { "type": "string" },
            "run_id": { "type": "string" },
            "attempt": { "type": "integer", "minimum": 1 },
            "github_actions_run_url": { "type": "string", "format": "uri" },
            "model_provider": { "type": ["string", "null"] },
            "model_name": { "type": "string" }
          }
        },

        "lifecycle": {
          "type": "object",
          "required": ["started_at", "ended_at", "duration_seconds"],
          "properties": {
            "started_at": { "type": "string", "format": "date-time" },
            "ended_at": { "type": "string", "format": "date-time" },
            "duration_seconds": { "type": "number", "minimum": 0 }
          }
        },

        "execution": {
          "type": "object",
          "required": ["turns", "tool_calls", "max_turns_hit"],
          "properties": {
            "turns": { "type": "integer", "minimum": 0 },
            "tool_calls": { "type": "integer", "minimum": 0 },
            "max_turns_hit": { "type": "boolean" },
            "compaction": {
              "type": "object",
              "properties": {
                "count": { "type": "integer", "minimum": 0 },
                "events": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "turn_count": { "type": "integer" },
                      "tokens_before": { "type": "integer" },
                      "tokens_after": { "type": "integer" },
                      "context_window": { "type": "integer" },
                      "retained_files": { "type": "integer" },
                      "summary_fields": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        },

        "trajectory": {
          "type": "array",
          "description": "Payload-free tool call trace. No secrets or file contents.",
          "items": {
            "type": "object",
            "required": ["tool", "status"],
            "properties": {
              "tool": { "type": "string" },
              "arg_shape": { "type": ["string", "null"] },
              "arg_hash": { "type": ["string", "null"] },
              "status": { "type": "string", "enum": ["ok", "error", "timeout"] }
            }
          }
        },

        "cost": {
          "type": "object",
          "required": ["input_tokens", "output_tokens", "total_tokens", "total_cost_usd"],
          "properties": {
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "total_tokens": { "type": "integer", "minimum": 0 },
            "input_cost_usd": { "type": ["number", "null"], "minimum": 0 },
            "output_cost_usd": { "type": ["number", "null"], "minimum": 0 },
            "total_cost_usd": { "type": ["number", "null"], "minimum": 0 },
            "modeled_cost_usd": {
              "type": ["number", "null"],
              "minimum": 0,
              "description": "Cost computed from model_rates.yml. Null if provider+model not in table."
            },
            "model_input_rate_usd": { "type": ["number", "null"] },
            "model_output_rate_usd": { "type": ["number", "null"] },
            "per_turn": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["input", "output"],
                "properties": {
                  "input": { "type": "integer", "minimum": 0 },
                  "output": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        },

        "friction": {
          "type": "object",
          "required": ["tool_errors", "retries"],
          "properties": {
            "tool_errors": { "type": "integer", "minimum": 0 },
            "retries": { "type": "integer", "minimum": 0 },
            "repeats": { "type": "integer", "minimum": 0 },
            "max_turns_proximity": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1,
              "description": "turns / max_turns ratio."
            },
            "tool_error_breakdown": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["tool", "count"],
                "properties": {
                  "tool": { "type": "string" },
                  "count": { "type": "integer", "minimum": 1 }
                }
              }
            }
          }
        },

        "context": {
          "type": "object",
          "properties": {
            "diff_lines_added": { "type": ["integer", "null"], "minimum": 0 },
            "diff_lines_removed": { "type": ["integer", "null"], "minimum": 0 },
            "files_changed_count": { "type": ["integer", "null"], "minimum": 0 },
            "issue_labels": {
              "type": "array",
              "items": { "type": "string" }
            },
            "model_version": { "type": ["string", "null"] },
            "context_inflation_ratio": { "type": ["number", "null"], "minimum": 0 }
          }
        },

        "clean_exit": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["clean", "crashed", "max_turns", "infra_failure"]
            },
            "detail": { "type": ["string", "null"] },
            "error": {
              "type": ["object", "null"],
              "properties": {
                "error_type": { "type": "string" },
                "tool": { "type": ["string", "null"] },
                "code": { "type": ["string", "integer", "null"] }
              }
            }
          }
        },

        "linkage": {
          "type": "object",
          "required": ["issue_number"],
          "properties": {
            "pr_number": { "type": ["integer", "null"], "minimum": 1 },
            "issue_number": { "type": "integer", "minimum": 1 },
            "previous_run_id": { "type": ["string", "null"] }
          }
        },

        "outcome": {
          "type": ["string", "null"],
          "enum": ["provisional", "merged", "closed_unmerged", "ci_failed", "reverted", "abandoned", null]
        }
      }
    },

    "settlement_record": {
      "description": "One record per PR close (merged or unmerged). Finalises the Outcome board field.",
      "type": "object",
      "required": ["schema_version", "event", "run_key", "settled_at", "outcome", "pr_number"],
      "properties": {
        "schema_version": { "type": "integer", "const": 6 },
        "event": { "type": "string", "const": "settlement" },
        "run_key": {
          "type": "string",
          "description": "Format: 'settlement|{repo}|{pr_number}'"
        },
        "settled_at": { "type": "string", "format": "date-time" },
        "outcome": {
          "type": "string",
          "enum": ["merged", "closed_unmerged", "ci_failed", "reverted", "abandoned"]
        },
        "ci_result": { "type": ["string", "null"] },
        "reviewer_verdict": { "type": ["string", "null"] },
        "reverted_at": { "type": ["string", "null"], "format": "date-time" },
        "reverted_by": { "type": ["string", "null"] },
        "pr_number": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
